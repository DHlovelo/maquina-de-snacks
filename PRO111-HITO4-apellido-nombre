

totest = 0
apro = 0
repnot = 0
repasis = 0
sumnot = 0

op = "S"

while op.upper() == "S":

    nombre = input("Ingrese el nombre del estudiante: ")

    clapro = int(input("Ingrese la cantidad de clases programadas: "))
    clasis = int(input("Ingrese la cantidad de clases asistidas: "))
    nota = float(input("Ingrese la calificación final: "))

    asis = (clasis * 100) / clapro

    if asis < 80:
        estado = "Reprobado por asistencia"
        repasis += 1

    else:
        if nota >= 51:
            estado = "Aprobado"
            apro += 1
        else:
            estado = "Reprobado por nota"
            repnot += 1

    print("\n--- RESULTADO DEL ESTUDIANTE ---")
    print("Nombre:", nombre)
    print("Asistencia:", round(asis, 2), "%")
    print("Nota:", nota)
    print("Estado:", estado)

    totest += 1
    sumnot += nota

    op = input("\n¿Desea registrar otro estudiante? (S/N): ")

if totest > 0:
    prom = sumnot / totest
else:
    prom = 0

print("\n===== RESUMEN FINAL =====")
print("Total de estudiantes:", totest)
print("Cantidad de aprobados:", apro)
print("Cantidad de reprobados por nota:", repnot)
print("Cantidad de reprobados por asistencia:", repasis)
print("Promedio general de notas:", round(prom, 2))